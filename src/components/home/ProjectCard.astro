---
type Theme = 'dark' | 'paper' | 'yellow' | 'blue';

interface Credit {
	role: string;
	name: string;
}

interface Props {
	id?: string;
	theme?: Theme;
	titleLines?: string[];
	overview?: string;
	quote?: string;
	author?: string;
	/**
	 * Seven image slots driving the collage (offsets matched to the
	 * Webflow /work page). In order:
	 *   0 hero 4:3, 1 portrait 3:4,
	 *   2 portrait 3:4, 3 portrait 3:4, 4 tall 9:16,
	 *   5 landscape 4:3, 6 wide ~2:1 (41/20)
	 */
	images?: string[];
	/** Content for the "More info" detail panel. */
	brief?: string;
	whatChanged?: string;
	credits?: Credit[];
	detailImage?: string;
}

const PLACEHOLDER = '/figma/project.png';

const {
	id,
	theme = 'paper',
	titleLines = ['Chapel Allerton Arts Festival', '_All for a good cause'],
	overview = 'Chapel Allerton Arts Festival is a brand identity and Webflow website project for a local arts and community festival, covering visual identity, print, brand guidelines and event promotion.',
	quote = '“Kris created a colourful, flexible identity and practical Webflow website that helped the festival present its events more clearly and consistently across digital and print.”',
	author = '—James Flegg',
	images = [],
	brief = 'Chapel Allerton Arts Festival is a brand identity and Webflow website project for a local arts and community festival, covering visual identity, print, brand guidelines and event promotion.',
	whatChanged = 'I developed a flexible visual system that could work across the website, social posts, posters and event listings. The site was designed to make the programme easy to browse, with a structure that could be updated as new events were added.',
	credits = [
		{ role: 'Direction', name: 'Kris Howes' },
		{ role: 'Copywriting', name: 'Kris Howes' },
		{ role: 'Photography', name: 'Kris Howes' },
		{ role: 'Design', name: 'Kris Howes' },
		{ role: 'Build', name: 'Kris Howes' },
	],
	detailImage = PLACEHOLDER,
} = Astro.props;

const detailId = `${id ?? 'project'}-detail`;

const img = (i: number) => images[i] ?? PLACEHOLDER;

const themes: Record<Theme, { body: string; label: string; copy: string; border: string }> = {
	dark: { body: 'bg-card-dark', label: 'text-white/55', copy: 'text-coral', border: 'border-white/15' },
	paper: { body: 'bg-white', label: 'text-cocoa/55', copy: 'text-coral', border: 'border-black/15' },
	yellow: { body: 'bg-card-yellow', label: 'text-cocoa', copy: 'text-cocoa', border: 'border-black/20' },
	blue: { body: 'bg-card-blue', label: 'text-white/70', copy: 'text-coral', border: 'border-white/15' },
};

const t = themes[theme];
---

<article id={id} class:list={['w-full scroll-mt-24', t.body]}>
	<!-- Header: sticks 100px below the top so it clears the sticky K-logo nav
	     while the project's images scroll behind it (mirrors Webflow's
	     .project-header { position: sticky; top: 100px; z-index: 10 }). -->
	<div class="sticky top-[100px] bottom-[100px] z-10 px-6 pt-6 pb-12 md:pb-20">
		<div class="text-[clamp(1.75rem,3.4vw,3rem)] leading-[1.3] font-medium text-coral">
			{titleLines.map((line) => <p>{line}</p>)}
		</div>
	</div>

	<!--
		Project image collage. Offsets/aspect ratios mirror the Webflow /work
		page, which uses a 12-column grid (40px gutters, ~158px columns).
		Gaps between non-adjacent images come from empty/offset columns;
		all images are object-cover centred (object-position 50% 50%).
		Stacks to a single column below lg.
	-->
	<div class="project-collage flex flex-col gap-10 px-6 pb-6 lg:gap-[128px]">
		<!-- Row 1: 4:3 hero (8 cols) + top-aligned 3:4 portrait flush right (3 cols, 1-col gap) -->
		<div class="project-collage-row grid grid-cols-1 gap-6 lg:grid-cols-12 lg:items-start lg:gap-x-[40px] lg:gap-y-0">
			{
				[
					[0, 'aspect-[4/3] lg:col-span-8'],
					[1, 'aspect-[3/4] lg:col-span-3 lg:col-start-10'],
				].map(([index, cls]) => (
					<div class:list={['project-image', cls]} data-project-image>
						<div class="project-image__clip">
							<img src={img(Number(index))} alt="" decoding="async" />
						</div>
					</div>
				))
			}
		</div>

		<!-- Row 2: two 3:4 portraits (cols 1-3, 4-6) + offset tall 9:16 (cols 9-12) -->
		<div class="project-collage-row grid grid-cols-1 gap-6 lg:grid-cols-12 lg:items-start lg:gap-x-[40px] lg:gap-y-0">
			{
				[
					[2, 'aspect-[3/4] lg:col-span-3'],
					[3, 'aspect-[3/4] lg:col-span-3'],
					[4, 'aspect-[9/16] lg:col-span-4 lg:col-start-9'],
				].map(([index, cls]) => (
					<div class:list={['project-image', cls]} data-project-image>
						<div class="project-image__clip">
							<img src={img(Number(index))} alt="" decoding="async" />
						</div>
					</div>
				))
			}
		</div>

		<!-- Row 3: 4:3 landscape (cols 1-4) + offset ~2:1 wide flush right (cols 7-12) -->
		<div class="project-collage-row grid grid-cols-1 gap-6 lg:grid-cols-12 lg:items-start lg:gap-x-[40px] lg:gap-y-0">
			{
				[
					[5, 'aspect-[4/3] lg:col-span-4'],
					[6, 'aspect-[41/20] lg:col-span-6 lg:col-start-7'],
				].map(([index, cls]) => (
					<div class:list={['project-image', cls]} data-project-image>
						<div class="project-image__clip">
							<img src={img(Number(index))} alt="" decoding="async" />
						</div>
					</div>
				))
			}
		</div>
	</div>

	<!-- Overview / quote -->
	<div class:list={['border-t px-6 py-8 md:px-12 lg:grid lg:grid-cols-2 lg:gap-12', t.border]}>
		<div class="hidden lg:block" aria-hidden="true"></div>
		<div class="flex flex-col gap-10 md:flex-row md:gap-12">
			<div class="flex flex-1 flex-col gap-6">
				<p class:list={['font-mono text-eyebrow font-medium tracking-[0.18em] uppercase', t.label]}>
					overview
				</p>
				<p class:list={['text-[clamp(1.5rem,2.6vw,3rem)] leading-[1.3] font-medium', t.copy]}>
					{overview}
				</p>
				<button
					type="button"
					data-detail-open={detailId}
					aria-haspopup="dialog"
					class="group inline-flex w-fit cursor-pointer items-center gap-3 text-coral transition-opacity hover:opacity-70"
				>
					<span class="size-[33px] rounded-full bg-coral"></span>
					<span class="text-xl leading-none font-medium">More info</span>
				</button>
			</div>
			<div class="flex flex-col gap-6 md:w-[300px] md:shrink-0">
				<p class:list={['font-mono text-eyebrow font-medium tracking-[0.18em] uppercase', t.label]}>
					the client said
				</p>
				<p class:list={['text-2xl leading-[1.4] font-medium', t.copy]}>{quote}</p>
				<p class:list={['text-2xl leading-[1.4] font-medium', t.copy]}>{author}</p>
			</div>
		</div>
	</div>
</article>

<style>
	.project-image {
		position: relative;
		container-type: inline-size;
		overflow: hidden;
		background-color: #d1d1d1;
	}

	/* Width-based mask — no clip-path compositor layer */
	.project-image__clip {
		position: absolute;
		top: 0;
		left: 0;
		bottom: 0;
		width: 30%;
		overflow: hidden;
	}

	.project-image__clip img {
		position: absolute;
		top: 0;
		left: 0;
		height: 100%;
		width: 100cqw;
		max-width: none;
		object-fit: cover;
		object-position: center;
	}

	/* Flatten to a plain img after reveal — nothing to desync on scroll */
	.project-image.is-revealed img {
		position: absolute;
		inset: 0;
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}
</style>

<!-- "More info" detail panel: coral X-masked image (left) + dark content (right) -->
<div
	id={detailId}
	class="project-detail fixed inset-0 z-50 hidden"
	role="dialog"
	aria-modal="true"
	aria-label={`${titleLines[0]} — project details`}
	aria-hidden="true"
>
	<div class="grid h-full w-full grid-rows-2 md:grid-cols-2 md:grid-rows-1">
		<!-- Left: click anywhere (or the X) to close -->
		<button
			type="button"
			data-detail-close
			aria-label="Close details"
			class="detail-left relative flex cursor-pointer items-center justify-center overflow-hidden bg-coral"
		>
			<div class="x-image-mask aspect-square w-[78%] max-w-[520px]">
				<img src={detailImage} alt="" class="size-full object-cover" />
			</div>
		</button>

		<!-- Right: project details -->
		<div
			class="detail-right relative flex flex-col overflow-y-auto bg-cocoa-dark px-7 py-12 text-coral md:px-14 md:py-16"
		>
			<div class="flex flex-col gap-7">
				<section class="flex flex-col gap-3">
					<h2 class="text-[clamp(1.05rem,1.3vw,1.35rem)] leading-[1.4] font-medium text-white">
						Overview
					</h2>
					<p class="text-[clamp(1.05rem,1.3vw,1.35rem)] leading-[1.4] font-medium">{overview}</p>
				</section>

				<hr class="border-coral/20" />

				<section class="flex flex-col gap-3">
					<h2 class="text-[clamp(1.05rem,1.3vw,1.35rem)] leading-[1.4] font-medium text-white">
						The brief
					</h2>
					<p class="text-[clamp(1.05rem,1.3vw,1.35rem)] leading-[1.4] font-medium">{brief}</p>
				</section>

				<hr class="border-coral/20" />

				<section class="flex flex-col gap-3">
					<h2 class="text-[clamp(1.05rem,1.3vw,1.35rem)] leading-[1.4] font-medium text-white">
						What changed
					</h2>
					<p class="text-[clamp(1.05rem,1.3vw,1.35rem)] leading-[1.4] font-medium">{whatChanged}</p>
				</section>

				<hr class="border-coral/20" />

				<section class="flex flex-col gap-4">
					<h2 class="text-[clamp(1.05rem,1.3vw,1.35rem)] leading-[1.4] font-medium text-white">
						Credits
					</h2>
					<div class="flex items-end justify-between gap-6">
						<dl class="grid grid-cols-[auto_1fr] gap-x-12 gap-y-3 text-base">
							{
								credits.map((c) => (
									<>
										<dt class="font-medium">{c.role}</dt>
										<dd class="font-medium">{c.name}</dd>
									</>
								))
							}
						</dl>
						<img
							src={detailImage}
							alt=""
							class="hidden h-24 w-32 shrink-0 object-cover sm:block md:h-28 md:w-40"
						/>
					</div>
				</section>
			</div>

			<button
				type="button"
				data-detail-close
				aria-label="Close details"
				class="absolute right-6 bottom-6 cursor-pointer text-coral transition-opacity hover:opacity-70"
			>
				<svg viewBox="0 0 24 24" class="size-7" fill="none" stroke="currentColor" stroke-width="1.5">
					<path d="M5 5 19 19M19 5 5 19" stroke-linecap="round" />
				</svg>
			</button>
		</div>
	</div>
</div>

<script>
	import gsap from 'gsap';

	const timelines = new WeakMap<HTMLElement, gsap.core.Timeline>();

	// Lock background scroll while a panel is open, compensating for the
	// scrollbar's width so the page underneath doesn't jump sideways.
	function lockScroll() {
		const sbw = window.innerWidth - document.documentElement.clientWidth;
		document.body.style.overflow = 'hidden';
		if (sbw > 0) document.body.style.paddingRight = `${sbw}px`;
	}

	function unlockScroll() {
		document.body.style.overflow = '';
		document.body.style.paddingRight = '';
	}

	function setupDetail(overlay: HTMLElement) {
		if (timelines.has(overlay)) return;
		const left = overlay.querySelector<HTMLElement>('.detail-left');
		const right = overlay.querySelector<HTMLElement>('.detail-right');
		const leftImg = overlay.querySelector<HTMLElement>('.detail-left img');
		const tl = gsap.timeline({
			paused: true,
			onReverseComplete() {
				overlay.classList.add('hidden');
				overlay.setAttribute('aria-hidden', 'true');
				unlockScroll();
			},
		});
		if (left) tl.from(left, { xPercent: -100, duration: 0.6, ease: 'power3.out' }, 0);
		if (right) tl.from(right, { xPercent: 100, duration: 0.6, ease: 'power3.out' }, 0);
		// Masked image animates in lockstep with the panel (same start + duration,
		// no slide-then-scale). It both zooms out and trails the panel's motion
		// (xPercent) for a parallax "drag". The scale stays > 1 while there's any
		// x offset, so the enlarged image always fully fills the X; both reach
		// their rest state (scale 1, x 0) together. Only the <img> moves — the X
		// mask wrapper keeps its size.
		if (leftImg)
			tl.from(leftImg, { xPercent: -50, scale: 2, duration: 0.6, ease: 'power3.out' }, 0);
		timelines.set(overlay, tl);
		overlay
			.querySelectorAll<HTMLElement>('[data-detail-close]')
			.forEach((btn) => btn.addEventListener('click', () => closeDetail(overlay)));
	}

	function openDetail(id: string | null) {
		if (!id) return;
		const overlay = document.getElementById(id);
		if (!overlay) return;
		setupDetail(overlay);
		overlay.classList.remove('hidden');
		overlay.setAttribute('aria-hidden', 'false');
		lockScroll();
		timelines.get(overlay)?.play(0);
	}

	function closeDetail(overlay: HTMLElement) {
		timelines.get(overlay)?.reverse();
	}

	function onEsc(e: KeyboardEvent) {
		if (e.key !== 'Escape') return;
		document
			.querySelectorAll<HTMLElement>('.project-detail:not(.hidden)')
			.forEach((overlay) => closeDetail(overlay));
	}

	function initProjectDetails() {
		document.querySelectorAll<HTMLElement>('.project-detail').forEach(setupDetail);
		document.querySelectorAll<HTMLElement>('[data-detail-open]').forEach((btn) => {
			if (btn.dataset.bound) return;
			btn.dataset.bound = 'true';
			btn.addEventListener('click', () => openDetail(btn.getAttribute('data-detail-open')));
		});
		document.addEventListener('keydown', onEsc);
	}

	initProjectDetails();
	document.addEventListener('astro:page-load', initProjectDetails);
</script>
