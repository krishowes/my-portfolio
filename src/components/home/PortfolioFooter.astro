---
interface FooterLink {
	label: string;
	href: string;
}

interface Props {
	links?: FooterLink[];
	/** Reserve right padding so a floating chat button doesn't overlap the copyright. */
	reserveChatSpace?: boolean;
}

const {
	links = [
		{ label: 'Instagram', href: '#' },
		{ label: 'Framerate', href: '#' },
		{ label: 'LinkedIn', href: '#' },
	],
	reserveChatSpace = false,
} = Astro.props;

const year = new Date().getFullYear();
---

<footer
	class:list={[
		'flex flex-wrap items-end justify-between gap-x-8 gap-y-8 px-6 py-20 text-2xl font-medium text-ink md:py-24',
		reserveChatSpace && 'pr-28 md:pr-48',
	]}
>
	<div class="leading-[1.3]">
		{links.map((l) => (
			<p><a href={l.href} class="transition-opacity hover:opacity-60">{l.label}</a></p>
		))}
	</div>
	<p class="text-right">© {year} Kris Howes</p>
</footer>
