---
interface Props {
	shadedSrc: string;
	alt: string;
	/** Optional wireframe/topology model — enables the Shaded/Topology toggle. */
	topoSrc?: string;
	/** Optional poster image shown before the model is revealed. */
	poster?: string;
	height?: string;
}

const { shadedSrc, alt, topoSrc, poster, height = 'min(70vh, 540px)' } = Astro.props;
const uid = `mv-${Math.random().toString(36).slice(2, 9)}`;
const hasToggle = Boolean(topoSrc);
---

<div
	class="model-viewer-root"
	data-model-viewer-root
	data-model-viewer-id={uid}
	data-shaded-src={shadedSrc}
	data-topo-src={topoSrc}
	style={`--model-viewer-height: ${height}`}
>
	{
		hasToggle && (
			<div class="model-viewer-root__toolbar" role="toolbar" aria-label="3D model display mode">
				<button
					type="button"
					class="model-viewer-root__mode is-active"
					data-model-mode="shaded"
					aria-pressed="true"
				>
					Shaded
				</button>
				<button
					type="button"
					class="model-viewer-root__mode"
					data-model-mode="topology"
					aria-pressed="false"
				>
					Topology
				</button>
			</div>
		)
	}

	<div class="model-viewer-root__stage">
		<model-viewer
			src={shadedSrc}
			poster={poster}
			alt={alt}
			camera-controls
			auto-rotate
			touch-action="pan-y"
			loading="lazy"
			reveal="interaction"
			interaction-prompt="none"
			shadow-intensity="0"
			environment-image="neutral"
			data-model-viewer
		>
			<button slot="poster" type="button" class="model-viewer-root__poster-btn">
				View 3D model
			</button>
		</model-viewer>
	</div>

	<p class="model-viewer-root__hint">Drag to rotate · Scroll or pinch to zoom</p>
</div>

<style>
	.model-viewer-root {
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.model-viewer-root__toolbar {
		display: inline-flex;
		align-self: flex-start;
		gap: 0.35rem;
		padding: 0.25rem;
		border-radius: 999px;
		background: rgba(51, 42, 42, 0.06);
		border: 1px solid rgba(51, 42, 42, 0.12);
	}

	.model-viewer-root__mode {
		appearance: none;
		border: 0;
		border-radius: 999px;
		padding: 0.45rem 0.9rem;
		font: inherit;
		font-size: 0.8125rem;
		font-weight: 500;
		line-height: 1;
		color: #473c3c;
		background: transparent;
		cursor: pointer;
		transition:
			background-color 0.15s ease,
			color 0.15s ease,
			box-shadow 0.15s ease;
	}

	.model-viewer-root__mode:hover {
		background: rgba(254, 128, 95, 0.12);
	}

	.model-viewer-root__mode.is-active {
		background: #fe805f;
		color: #fff;
		box-shadow: 0 1px 2px rgba(51, 42, 42, 0.12);
	}

	.model-viewer-root__stage {
		width: 100%;
		height: var(--model-viewer-height, min(70vh, 540px));
		min-height: 240px;
		border-radius: 12px;
		border: 1px solid rgba(51, 42, 42, 0.12);
		background: linear-gradient(160deg, rgba(238, 243, 231, 0.9), rgba(255, 255, 255, 0.65));
		overflow: hidden;
	}

	model-viewer {
		width: 100%;
		height: 100%;
		--poster-color: transparent;
		background-color: transparent;
	}

	.model-viewer-root__poster-btn {
		appearance: none;
		border: 1px solid rgba(51, 42, 42, 0.2);
		border-radius: 999px;
		padding: 0.65rem 1.1rem;
		font: inherit;
		font-size: 0.875rem;
		font-weight: 500;
		color: #473c3c;
		background: rgba(255, 255, 255, 0.92);
		box-shadow: 0 2px 8px rgba(51, 42, 42, 0.12);
		cursor: pointer;
		transition:
			transform 0.15s ease,
			background-color 0.15s ease;
	}

	.model-viewer-root__poster-btn:hover {
		background: #fff;
		transform: translateY(-1px);
	}

	.model-viewer-root__hint {
		margin: 0;
		font-size: 0.75rem;
		line-height: 1.4;
		color: rgba(71, 60, 60, 0.65);
	}

	@media (max-width: 640px) {
		.model-viewer-root__stage {
			min-height: 220px;
			border-radius: 10px;
		}

		.model-viewer-root__mode {
			padding: 0.5rem 0.8rem;
		}
	}
</style>

<script>
	type ModelViewerElement = HTMLElement & {
		src: string;
		getCameraOrbit(): { theta: number; phi: number; radius: number };
		getCameraTarget(): { x: number; y: number; z: number };
		cameraOrbit: string;
		cameraTarget: string;
	};

	function setActiveMode(root: HTMLElement, mode: 'shaded' | 'topology') {
		root.querySelectorAll<HTMLButtonElement>('[data-model-mode]').forEach((btn) => {
			const isActive = btn.dataset.modelMode === mode;
			btn.classList.toggle('is-active', isActive);
			btn.setAttribute('aria-pressed', String(isActive));
		});
	}

	function switchModel(root: HTMLElement, mode: 'shaded' | 'topology') {
		const viewer = root.querySelector<ModelViewerElement>('[data-model-viewer]');
		if (!viewer) return;

		const shadedSrc = root.dataset.shadedSrc;
		const topoSrc = root.dataset.topoSrc;
		const nextSrc = mode === 'shaded' ? shadedSrc : topoSrc;
		if (!nextSrc || viewer.src === nextSrc) {
			setActiveMode(root, mode);
			return;
		}

		const orbit = viewer.getCameraOrbit();
		const target = viewer.getCameraTarget();
		const orbitString = `${orbit.theta}rad ${orbit.phi}rad ${orbit.radius}m`;
		const targetString = `${target.x}m ${target.y}m ${target.z}m`;

		const restoreCamera = () => {
			viewer.cameraOrbit = orbitString;
			viewer.cameraTarget = targetString;
		};

		viewer.addEventListener('load', restoreCamera, { once: true });
		viewer.src = nextSrc;
		setActiveMode(root, mode);
	}

	function initModelViewers() {
		document.querySelectorAll<HTMLElement>('[data-model-viewer-root]').forEach((root) => {
			if (root.dataset.bound === 'true') return;
			root.dataset.bound = 'true';

			// Explicitly reveal the model when the poster button is clicked, so it
			// works reliably regardless of model-viewer's built-in interaction reveal.
			const viewer = root.querySelector<HTMLElement & { dismissPoster?: () => void }>(
				'[data-model-viewer]',
			);
			const posterBtn = root.querySelector<HTMLButtonElement>('.model-viewer-root__poster-btn');
			posterBtn?.addEventListener('click', () => {
				viewer?.dismissPoster?.();
			});

			root.querySelectorAll<HTMLButtonElement>('[data-model-mode]').forEach((btn) => {
				btn.addEventListener('click', () => {
					const mode = btn.dataset.modelMode as 'shaded' | 'topology';
					switchModel(root, mode);
				});
			});
		});
	}

	initModelViewers();
	document.addEventListener('astro:page-load', initModelViewers);
</script>
