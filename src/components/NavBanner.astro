---
interface Props {
	message?: string;
	href?: string;
	class?: string;
}

const {
	message = 'Mast — a CSS framework for Webflow',
	href = 'https://mast.build',
	class: className,
} = Astro.props;
---

<aside
	class:list={[
		'border-b border-line bg-brand px-[var(--spacing-gutter)] py-2 text-center text-body-sm text-white',
		className,
	]}
>
	<a href={href} class="font-medium underline underline-offset-2 hover:text-paper">
		{message}
	</a>
</aside>
